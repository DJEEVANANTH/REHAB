{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently --kill-others-on-fail --prefix-colors \"bgBlue.bold,bgGreen.bold,bgYellow.bold\" --names \"FRONTEND,BACKEND,DETECTION\" \"vite --port=3000 --host=0.0.0.0\" \".\\\\node_modules\\\\.bin\\\\tsx.cmd server.ts\" \"python detection_server.py\"",
    "dev:no-detection": "concurrently --kill-others-on-fail --prefix-colors \"bgBlue.bold,bgGreen.bold\" --names \"FRONTEND,BACKEND\" \"vite --port=3000 --host=0.0.0.0\" \"npx tsx server.ts\"",
    "dev:frontend": "vite --port=3000 --host=0.0.0.0",
    "server": "npx tsx server.ts",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "test:e2e": "vitest run tests/e2e",
    "test:selenium": "cross-env NODE_ENV=test mocha \"selenium-framework/tests/**/*.test.js\" --timeout 60000 --reporter mochawesome --reporter-options reportDir=selenium-framework/reports,reportFilename=mochawesome,html=true,json=true",
    "test:selenium:headless": "cross-env HEADLESS=true npm run test:selenium",
    "test:selenium:chrome": "cross-env BROWSER=chrome npm run test:selenium",
    "test:selenium:firefox": "cross-env BROWSER=firefox npm run test:selenium",
    "test:selenium:edge": "cross-env BROWSER=edge npm run test:selenium"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@supabase/supabase-js": "^2.106.2",
    "@tailwindcss/vite": "^4.1.14",
    "@types/cors": "^2.8.19",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mongoose": "^5.11.96",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.20.0",
    "@vitejs/plugin-react": "^5.0.4",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.546.0",
    "mongoose": "^9.6.3",
    "motion": "^12.23.24",
    "nodemailer": "^8.0.9",
    "pg": "^8.21.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.6.0",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/selenium-webdriver": "^4.1.28",
    "autoprefixer": "^10.4.21",
    "chai": "^4.5.0",
    "chromedriver": "^133.0.0",
    "concurrently": "^10.0.0",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "esbuild": "^0.25.0",
    "exceljs": "^4.4.0",
    "mocha": "^11.7.6",
    "mochawesome": "^7.1.4",
    "mochawesome-merge": "^5.1.1",
    "mochawesome-report-generator": "^6.3.2",
    "puppeteer": "^25.1.0",
    "selenium-webdriver": "^4.45.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "vitest": "^3.0.6",
    "wait-on": "^9.0.10",
    "winston": "^3.19.0"
  }
}
